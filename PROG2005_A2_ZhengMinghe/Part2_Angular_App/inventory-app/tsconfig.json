  "compileOnSave": false,
  "compilerOptions": {
    "outDir": "./dist/out-tsc", // Directory for compiled JavaScript output files
    "strict": true, // Enable all strict type-checking to ensure code robustness and data integrity
    "noImplicitOverride": true,
